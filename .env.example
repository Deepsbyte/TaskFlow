# ============================================================================
# Django Settings - Required for production deployment
# ============================================================================

# Secret key for cryptographic signing (Django sessions, CSRF tokens, etc.)
# Generate a new one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-me-in-production

# Debug mode - MUST be False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hosts (e.g., example.com,www.example.com,localhost)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# If POSTGRES_DB is set, Django uses PostgreSQL; otherwise defaults to SQLite.
# Uncomment and set these for production:

POSTGRES_DB=taskflow
POSTGRES_USER=taskflow_user
POSTGRES_PASSWORD=secure_password_change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins for frontend requests
# Example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Alternatively, set this to True ONLY in development for quick testing:
CORS_ALLOW_ALL_ORIGINS=False

# ============================================================================
# Celery & Redis Configuration (for task queue and caching)
# ============================================================================
# Celery broker (message queue) - typically Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend - where task results are stored
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================================================
# Email Configuration (optional, for notifications)
# ============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@taskflow.local
